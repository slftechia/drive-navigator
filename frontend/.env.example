# Local: proxy Vite em /api
# VITE_API_URL=/api

# Producao: API no Render (ver frontend/.env.production)
# VITE_API_URL=https://drive-navigator-api.onrender.com/api

# Google Places (recomendado para busca igual Maps/Waze).
# Ative "Places API (New)" no Google Cloud e restrinja a chave ao dominio do app.
# VITE_GOOGLE_MAPS_API_KEY=
